# ============================================
# Alpaca API Credentials
# ============================================
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true

# ============================================
# Telegram Bot Credentials
# ============================================
TELEGRAM_TOKEN=your_telegram_token
TELEGRAM_CHAT_ID=your_chat_id

# ============================================
# Trading Configuration
# ============================================
TRADING_SYMBOL=BTC/USD
TRADE_QTY=0.001
MAX_DAILY_LOSS_PCT=5.0
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_MINUTES=30

# ---- CM Sling Shot System ----
CM_FAST_EMA=38
CM_SLOW_EMA=62

# ---- StochRSI (3, 3, 8, 10) ----
STOCH_RSI_K=3
STOCH_RSI_D=3
STOCH_RSI_RSI_PERIOD=8
STOCH_RSI_STOCH_PERIOD=10
STOCH_RSI_OVERSOLD=5
STOCH_RSI_OVERBOUGHT=95

# ---- WaveTrend ----
WT_CHANNEL_LEN=10
WT_AVG_LEN=21
WT_SIGNAL_LEN=4
WT_OVERSOLD=-53
WT_OVERBOUGHT=53

# ---- MACD ----
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# ---- Risk Management ----
STOP_LOSS_ATR_MULT=1.5
TAKE_PROFIT_ATR_MULT=3.0
TRAILING_STOP_ACTIVATE=false

# ============================================
# Flask / Web Dashboard
# ============================================
FLASK_PORT=10000
FLASK_HOST=0.0.0.0
FLASK_DEBUG=false
